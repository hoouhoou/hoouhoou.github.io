<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Master Content Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .thick-border { border: 2px solid #e2e8f0; }
        .row-hover:hover { background-color: #f8fafc; transition: 0.2s; }
    </style>
</head>
<body class="bg-slate-100 p-6 font-sans">

    <div class="max-w-6xl mx-auto bg-white border-2 border-slate-300 rounded-2xl shadow-2xl overflow-hidden">
        
        <header class="bg-slate-900 p-6 flex justify-between items-center border-b-4 border-blue-600">
            <div>
                <h1 class="text-2xl font-black text-white uppercase tracking-tight">Master Content Dashboard</h1>
                <p class="text-blue-400 font-bold text-xs uppercase tracking-widest mt-1">Status Report: March 13, 2026</p>
            </div>
            <div class="text-right">
                <span class="text-slate-400 text-[10px] font-black uppercase">Total Series</span>
                <p class="text-white text-2xl font-black">08</p>
            </div>
        </header>

        <div class="p-6">
            <table class="w-full border-2 border-slate-200">
                <thead>
                    <tr class="bg-slate-50 text-[10px] font-black text-slate-500 uppercase tracking-widest border-b-2 border-slate-200">
                        <th class="px-6 py-4 text-left">Series Title</th>
                        <th class="px-4 py-4 text-center">Available</th>
                        <th class="px-6 py-4 text-left">Completion Status</th>
                        <th class="px-6 py-4 text-right">Inventory Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 text-sm">
                    <tr class="row-hover">
                        <td class="px-6 py-4 font-bold text-slate-800 tracking-tight">POPEYE CLASSIC</td>
                        <td class="px-4 py-4 text-center font-bold">25 / 40</td>
                        <td class="px-6 py-4">
                            <div class="w-full bg-slate-100 rounded-full h-2.5 border border-slate-200">
                                <div class="bg-blue-500 h-full rounded-full" style="width: 38%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right font-bold text-slate-500">Aug 29, 2026</td>
                    </tr>

                    <tr class="bg-red-50">
                        <td class="px-6 py-4 font-black text-red-700 italic underline">WYATT EARP S2</td>
                        <td class="px-4 py-4 text-center font-black text-red-700">02 / 39</td>
                        <td class="px-6 py-4">
                            <div class="w-full bg-red-200 rounded-full h-2.5 border border-red-300">
                                <div class="bg-red-600 h-full rounded-full" style="width: 95%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right font-black text-red-600">Mar 18, 2026</td>
                    </tr>

                    <tr class="row-hover">
                        <td class="px-6 py-4 font-bold text-slate-800 tracking-tight uppercase">Beverly Hillbillies S2</td>
                        <td class="px-4 py-4 text-center font-bold">15 / 36</td>
                        <td class="px-6 py-4">
                            <div class="w-full bg-slate-100 rounded-full h-2.5 border border-slate-200">
                                <div class="bg-blue-500 h-full rounded-full" style="width: 58%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right font-bold text-slate-500">Jul 04, 2026</td>
                    </tr>

                    <tr class="row-hover">
                        <td class="px-6 py-4 font-bold text-slate-800 tracking-tight uppercase">Annie Oakley S3</td>
                        <td class="px-4 py-4 text-center font-bold">16 / 33</td>
                        <td class="px-6 py-4">
                            <div class="w-full bg-slate-100 rounded-full h-2.5 border border-slate-200">
                                <div class="bg-blue-500 h-full rounded-full" style="width: 52%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right font-bold text-slate-500">May 06, 2026</td>
                    </tr>

                    <tr class="row-hover">
                        <td class="px-6 py-4 font-bold text-blue-800 tracking-tight uppercase">THE LONE RANGER</td>
                        <td class="px-4 py-4 text-center font-bold">30 / 50</td>
                        <td class="px-6 py-4">
                            <div class="w-full bg-slate-100 rounded-full h-2.5 border border-slate-200">
                                <div class="bg-indigo-500 h-full rounded-full" style="width: 40%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right font-bold text-slate-500">Sept 12, 2026</td>
                    </tr>

                    <tr class="row-hover">
                        <td class="px-6 py-4 font-bold text-blue-800 tracking-tight uppercase">BONANZA S1</td>
                        <td class="px-4 py-4 text-center font-bold">12 / 34</td>
                        <td class="px-6 py-4">
                            <div class="w-full bg-slate-100 rounded-full h-2.5 border border-slate-200">
                                <div class="bg-emerald-500 h-full rounded-full" style="width: 65%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right font-bold text-slate-500">Oct 05, 2026</td>
                    </tr>

                    <tr class="row-hover">
                        <td class="px-6 py-4 font-bold text-slate-800 tracking-tight uppercase">What's My Line</td>
                        <td class="px-4 py-4 text-center font-bold">15 / 40</td>
                        <td class="px-6 py-4">
                            <div class="w-full bg-slate-100 rounded-full h-2.5 border border-slate-200">
                                <div class="bg-blue-500 h-full rounded-full" style="width: 63%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right font-bold text-slate-500">May 03, 2026</td>
                    </tr>

                    <tr class="row-hover">
                        <td class="px-6 py-4 font-bold text-blue-800 tracking-tight uppercase">THE DICK VAN DYKE SHOW</td>
                        <td class="px-4 py-4 text-center font-bold">08 / 30</td>
                        <td class="px-6 py-4">
                            <div class="w-full bg-slate-100 rounded-full h-2.5 border border-slate-200">
                                <div class="bg-orange-500 h-full rounded-full" style="width: 73%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right font-bold text-slate-500">Nov 20, 2026</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="p-6 bg-slate-50 border-t-2 border-slate-200">
            <h2 class="text-sm font-black text-slate-800 mb-4 uppercase tracking-widest">Broadcast Transmission Schedule</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
                
                <div class="bg-white border-2 border-blue-400 p-4 rounded-xl shadow-sm">
                    <p class="text-[10px] font-black text-blue-600 mb-2 uppercase italic">Mon / Wed</p>
                    <div class="space-y-3">
                        <p class="text-xs font-bold leading-tight uppercase">Wyatt Earp S2<br><span class="text-slate-400">01:00 AM</span></p>
                        <p class="text-xs font-bold leading-tight uppercase">Annie Oakley<br><span class="text-slate-400">01:30 AM</span></p>
                    </div>
                </div>

                <div class="bg-white border-2 border-slate-200 p-4 rounded-xl">
                    <p class="text-[10px] font-black text-slate-400 mb-2 uppercase italic">Tue / Thu</p>
                    <div class="space-y-3">
                        <p class="text-xs font-bold leading-tight uppercase">The Lone Ranger<br><span class="text-slate-400">02:00 PM</span></p>
                        <p class="text-xs font-bold leading-tight uppercase text-indigo-700">Bonanza S1<br><span class="text-slate-400">08:00 PM</span></p>
                    </div>
                </div>

                <div class="bg-white border-2 border-slate-200 p-4 rounded-xl">
                    <p class="text-[10px] font-black text-slate-400 mb-2 uppercase italic">Friday</p>
                    <div class="space-y-3">
                        <p class="text-xs font-bold leading-tight uppercase text-slate-300">No Scheduled<br>Broadcast</p>
                    </div>
                </div>

                <div class="bg-white border-2 border-slate-800 p-4 rounded-xl shadow-sm">
                    <p class="text-[10px] font-black text-slate-800 mb-2 uppercase italic">Saturday</p>
                    <div class="space-y-3">
                        <p class="text-xs font-bold leading-tight uppercase">Popeye Classic<br><span class="text-slate-400">04:00 PM</span></p>
                        <p class="text-xs font-bold leading-tight uppercase">Hillbillies S2<br><span class="text-slate-400">04:30 PM</span></p>
                    </div>
                </div>

                <div class="bg-slate-900 border-2 border-slate-900 p-4 rounded-xl shadow-xl">
                    <p class="text-[10px] font-black text-yellow-400 mb-2 uppercase italic tracking-tighter">Sunday Special</p>
                    <div class="space-y-3">
                        <p class="text-xs font-bold leading-tight uppercase text-white underline decoration-blue-500">What's My Line<br><span class="text-slate-500">02:00 PM</span></p>
                        <p class="text-xs font-bold leading-tight uppercase text-white">Dick Van Dyke<br><span class="text-slate-500">08:00 PM</span></p>
                    </div>
                </div>

            </div>
        </div>
    </div>

</body>
</html>
